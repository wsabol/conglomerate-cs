# Copy to `.dev.vars` and fill in values for local `wrangler dev`.
# Non-secret config lives in wrangler.toml [vars].

# Invite emails (Resend) — https://resend.com/api-keys
# RESEND_API_KEY=re_xxxxxxxx

# Cloudflare Access allowlist updates
# CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# R2 presigned uploads (optional)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=conglomerate-media
# R2_ENDPOINT=

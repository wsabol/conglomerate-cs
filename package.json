{
  "name": "conglomerate-cs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "The Conglomerate - a private chronological band archive (Cloudflare Worker + React).",
  "scripts": {
    "dev": "vite",
    "dev:worker": "wrangler dev",
    "build": "npm run icons:generate && vite build",
    "preview": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "typecheck": "tsc -p tsconfig.client.json && tsc -p tsconfig.server.json && tsc -p tsconfig.node.json",
    "types": "wrangler types",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "seed:build": "tsx scripts/seed.ts",
    "seed:local": "npm run seed:build && wrangler d1 execute DB --local --file=seed/seed.generated.sql",
    "seed:remote": "npm run seed:build && wrangler d1 execute DB --remote --file=seed/seed.generated.sql",
    "export": "tsx scripts/export.ts",
    "icons:generate": "node scripts/generate-pwa-icons.mjs"
  },
  "dependencies": {
    "@fontsource/bodoni-moda": "^5.2.7",
    "@fontsource/cormorant-garamond": "^5.2.11",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/manrope": "^5.2.8",
    "aws4fetch": "^1.0.20",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.27",
    "luxon": "^3.7.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.0",
    "@cloudflare/workers-types": "^4.20260702.1",
    "@types/luxon": "^3.7.2",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/runner": "^4.1.9",
    "@vitest/snapshot": "^4.1.9",
    "drizzle-kit": "^0.31.10",
    "sharp": "^0.35.3",
    "tsx": "^4.22.5",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9",
    "wrangler": "^4.107.0"
  }
}
